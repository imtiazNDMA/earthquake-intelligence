act><rpIndName>Ghulam Akbar</rpIndName><rpOrgName>Geological Survey of Pakistan</rpOrgName><rpPosName>Assistant Director</rpPosName><rpCntInfo><cntPhone><voiceNum>+923433577510</voiceNum></cntPhone><cntAddress addressType="physical"><delPoint>Geoscience Advance Research Laboratory, GARL, Geological Survey of Pakistan, Chak shahzad park road islamabad</delPoint><city>islamabad</city><adminArea>islamabad</adminArea><postCode>44028</postCode><country>PK</country><country>PK</country><eMailAdd>akbar.samtia510@gmail.com</eMailAdd></cntAddress></rpCntInfo><role><RoleCd value="007"/></role></mdContact><mdDateSt>20260429</mdDateSt><mdStanName>ArcGIS Metadata</mdStanName><mdStanVer>1.0</mdStanVer><distInfo><distributor><distorCont><rpIndName>Ghulam Akbar</rpIndName><rpOrgName>Geological Survey of Pakistan</rpOrgName><rpPosName>Assistant Director</rpPosName><rpCntInfo><cntPhone><voiceNum>+923433577510</voiceNum></cntPhone><cntAddress addressType="postal"><delPoint>Geoscience Advance Research Laboratory, GARL, Park Enclave 2, Park Road Islamabad</delPoint><city>Islamabad</city><adminArea>Islamabad</adminArea><postCode>44028</postCode><country>PK</country><country>PK</country><eMailAdd>akbar.samtia510@gmail.com</eMailAdd></cntAddress></rpCntInfo><role><RoleCd value="005"/></role></distorCont></distributor><distTranOps><onLineSrc><linkage>nil</linkage></onLineSrc><transSize Sync="TRUE">0.000</transSize></distTranOps><distFormat><formatName Sync="TRUE">Shapefile</formatName></distFormat></distInfo><dataIdInfo><idCitation><resTitle>Tectonic Map of Pakistan</resTitle><date><pubDate>2025-06-01</pubDate></date><resEd>2nd</resEd><citRespParty><rpOrgName>Geological Survey of Pakistan (GSP)</rpOrgName><role><RoleCd value="006"/></role></citRespParty><citRespParty><rpOrgName>Geological Survey of Pakistan</rpOrgName><rpCntInfo><cntAddress><delPoint>Pakistan</delPoint></cntAddress></rpCntInfo><role><RoleCd value="010"/></role></citRespParty><presForm><PresFormCd value="005"/></presForm><presForm><fgdcGeoform>vector digital data</fgdcGeoform></presForm><otherCitDet>nil</otherCitDet></idCitation><idAbs>&lt;DIV STYLE="text-align:Left;"&gt;&lt;DIV&gt;&lt;P&gt;&lt;SPAN&gt;This dataset presents an updated tectonic framework of Pakistan, illustrating the spatial distribution of major tectonic units, structural domains, and fault systems. The compilation is based on a modified interpretation of the Tectonic Map of Pakistan (1984) and integrates recent geological mapping, published literature, and geospatial datasets. The map delineates key tectonic zones including fold-and-thrust belts, suture zones, magmatic arcs, and sedimentary basins, along with a comprehensive network of major fault lines. In addition to the tectonic framework, the dataset incorporates a seismotectonic component derived from earthquake records, highlighting the spatial relationship between active tectonic structures and seismicity patterns. GNSS station locations installed by the Geological Survey of Pakistan are included to provide constraints on present-day crustal deformation and active tectonic processes. A regional tectonic context of Asia is also integrated to place the tectonic evolution of Pakistan within the broader plate tectonic framework. The dataset provides a comprehensive and updated representation of the tectonic, structural, and seismotectonic architecture of Pakistan, supporting regional-scale geological interpretation, tectonic analysis, and geohazard assessment.&lt;/SPAN&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/DIV&gt;</idAbs><idPurp>The purpose of this dataset is to improve and refine the tectonic framework of Pakistan through the integration of recent research and updated datasets, and to support regional tectonic analysis, geological interpretation, and geohazard assessment.</idPurp><idCredit>Geological Survey of Pakistan, USGS, and various published geological studies and remote sensing datasets used in compilation.</idCredit><idStatus><ProgCd value="007"/></idStatus><idPoC><rpIndName>Ghulam Akbar</rpIndName><rpOrgName>Geological Survey of Pakistan</rpOrgName><rpPosName>Assistant Director</rpPosName><rpCntInfo><cntPhone><voiceNum>+923433577510</voiceNum></cntPhone><cntAddress addressType="physical"><delPoint>Geoscience Advance Research Laboratory, Park Enclave 2 Park Road Islamabad</delPoint><city>Islamabad</city><adminArea>Islamabad</adminArea><postCode>44028</postCode><country>PK</country><country>PK</country><eMailAdd>akbar.samtia510@gmail.com</eMailAdd></cntAddress></rpCntInfo><role><RoleCd value="007"/></role></idPoC><resMaint><maintFreq><MaintFreqCd value="005"/></maintFreq></resMaint><placeKeys><thesaName><resTitle>Tectonic Map of Pakistan</resTitle></thesaName><keyword>Tectonic map of Pakistan, tectonic units, fault lines, major fault lines, GNSS location in Pakistan, seismotectonic map of Pakistan, major earthquake map of Pakistan, major earthquake, tectonic zones of Pakistan, tectonic zones, and regional tectonic map of Asia.</keyword></placeKeys><themeKeys><thesaName><resTitle>ISO 19115 Topic Category</resTitle></thesaName><keyword>geoscientificInformation</keyword></themeKeys><searchKeys><keyword>geoscientificInformation</keyword><keyword>Tectonic map of Pakistan</keyword><keyword>tectonic units</keyword><keyword>fault lines</keyword><keyword>major fault lines</keyword><keyword>GNSS location in Pakistan</keyword><keyword>seismotectonic map of Pakistan</keyword><keyword>major earthquake map of Pakistan</keyword><keyword>major earthquake</keyword><keyword>tectonic zones of Pakistan</keyword><keyword>tectonic zones</keyword><keyword>and regional tectonic map of Asia.</keyword></searchKeys><resConst><LegConsts><useLimit>Unless otherwise stated, all data, metadata and related materials are considered to satisfy the quality standards relative to the purpose for which the data were collected. Although these data and associated metadata have been reviewed for accuracy and completeness and approved for release by the Geological Survey of Pakistan (GSP), no warranty expressed or implied is made regarding the display or utility of the data for other purposes, nor on all computer systems, nor shall the act of distribution constitute any such warranty.</useLimit><othConsts>No restrictions on access. Dataset is available for scientific and academic use</othConsts></LegConsts></resConst><resConst><Consts><useLimit>&lt;DIV STYLE="text-align:Left;"&gt;&lt;DIV&gt;&lt;P&gt;&lt;SPAN&gt;This dataset is intended for regional-scale geological and tectonic analysis. It should not be used for site-specific engineering or hazard assessment without detailed verification. Proper citation of the Geological Survey of Pakistan is required.&lt;/SPAN&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/DIV&gt;</useLimit></Consts></resConst><dataLang><languageCode value="eng"/><countryCode value="PAK" Sync="TRUE"/></dataLang><dataExt><exDesc>publication date</exDesc><tempEle><TempExtent><exTemp><TM_Period><tmBegin>1928-01-01</tmBegin><tmEnd>2025-01-01</tmEnd></TM_Period></exTemp></TempExtent></tempEle></dataExt><envirDesc Sync="TRUE"> Version 6.2 (Build 9200) ; Esri ArcGIS 10.9.1.28388</envirDesc><spatRpType><SpatRepTypCd value="001" Sync="TRUE"/></spatRpType><dataExt><geoEle xmlns=""><GeoBndBox esriExtentType="search"><exTypeCode Sync="TRUE">1</exTypeCode><westBL Sync="TRUE">61.240666</westBL><eastBL Sync="TRUE">79.231290</eastBL><northBL Sync="TRUE">35.361615</northBL><southBL Sync="TRUE">24.123598</southBL></GeoBndBox></geoEle></dataExt><tpCat><TopicCatCd value="008"/></tpCat><tpCat><TopicCatCd value="013"/></tpCat></dataIdInfo><dqInfo><dqScope><scpLvl><ScopeCd value="005"/></scpLvl></dqScope><report type="DQConcConsis"><measDesc>The dataset has been compiled through integration of multiple geological and tectonic sources of varying scales and resolutions. Standard quality control procedures were applied to ensure internal consistency, including checks for attribute completeness, duplication, and omission. Topological validation was performed where applicable to maintain spatial integrity; however, due to the regional scale of mapping and the generalized nature of tectonic boundaries, minor inconsistencies may persist. Tectonic unit classification and boundary delineation are inherently interpretative and subject to revision with the availability of new data. As such, attribute values may not fully capture the complexity of geological relationships in all areas. Users are advised to consult the map legend and associated documentation for accurate interpretation rather than relying solely on attribute fields.</measDesc></report><report type="DQCompOm"><measDesc>The dataset represents the interpreted distribution of tectonic units within the defined area, based on available data sources. Coverage is regionally complete but may omit smaller or poorly constrained features due to scale and data limitations. The dataset is suitable for regional analysis but not for detailed, site-specific interpretation. Users should consult higher-resolution data and supporting documentation where necessary.</measDesc></report><report type="DQQuanAttAcc"><measDesc>The attribute information assigned to tectonic units in this dataset is preliminary and subject to ongoing refinement. Due to the inherent complexity and technical challenges associated with tectonic classification and subdivision, comprehensive and high-resolution datasets are required to establish fully reliable attribute definitions. Users are therefore advised not to rely solely on the attribute table for detailed interpretation. For accurate and complete information, the map legend and accompanying documentation should be consulted.</measDesc></report><report type="DQAbsExtPosAcc" dimension="horizontal"><measDesc>Horizontal positional accuracy is constrained by the scale and resolution of source data used in compilation.</measDesc></report><report type="DQAbsExtPosAcc" dimension="vertical"><measDesc>Vertical accuracy is not applicable, as the dataset represents planar tectonic features without elevation attributes. No vertical measurements are included</measDesc></report><dataLineage><dataSource><srcDesc>The Tectonic Map of Pakistan (1984/1990) provided the base framework, supplemented by published literature, seismic and GNSS data, and remote sensing (Sentinel-2 and Google Earth) for refinement, validation, and integration within a GIS environment.</srcDesc><srcMedName><MedNameCd value="018"/></srcMedName><srcScale><rfDenom>2000000</rfDenom></srcScale><srcCitatn><resTitle>Tectonic Map of Pakistan (1984), along with supplementary datasets as cited in the map layout references</resTitle><resAltTitle>Geological Survey of Pakistan Geological maps of different scales</resAltTitle><date><pubDate>2025-06-01</pubDate></date><resEd>1st</resEd><citRespParty><rpOrgName>Geological Survey of Pakistan</rpOrgName><role><RoleCd value="006"/></role></citRespParty><presForm><fgdcGeoform>publication</fgdcGeoform></presForm><citOnlineRes><linkage>still under process</linkage></citOnlineRes></srcCitatn><srcExt><exDesc>ground condition</exDesc><tempEle><TempExtent><exTemp><TM_Period><tmBegin>1930-01-01</tmBegin><tmEnd>2025-01-01</tmEnd></TM_Period></exTemp></TempExtent></tempEle></srcExt></dataSource><prcStep><stepDesc>The tectonic map of Pakistan was developed by integrating the Tectonic Map of Pakistan (1984/1990) with updated geological datasets using ArcGIS 10.8.2 and QGIS. Legacy maps were georeferenced using latitude–longitude grids and incorporated into a unified coordinate system. Major tectonic units, fault lines, and structural features were digitized into new shapefiles and classified using standardized legends. Tectonic zonation was refined through literature review and data compilation, while seismotectonic information was integrated using earthquake data. GNSS station locations installed by the Geological Survey of Pakistan were included to represent present-day crustal deformation. Validation of mapped features was carried out using Sentinel-2 imagery, Google Earth, and available ground observations. The final dataset provides an updated and comprehensive representation of the tectonic framework of Pakistan.</stepDesc><stepDateTm>2025-06-01</stepDateTm><stepProc><rpIndName>Ghulam Akbar</rpIndName><rpOrgName>GSP</rpOrgName><rpPosName>Assistant Director</rpPosName><rpCntInfo><cntPhone><voiceNum>+923433577510</voiceNum></cntPhone><cntAddress><delPoint>Geoscience Advance Research Laboratory, GARL, Park Enclave 2, Park Road Islamabad</delPoint><city>islamabad</city><adminArea>islamabad</adminArea><postCode>44028</postCode><country>Pakistab</country><eMailAdd>akbar.samtia510@gmail.com</eMailAdd></cntAddress></rpCntInfo><role><RoleCd value="009"/></role></stepProc></prcStep></dataLineage></dqInfo><mdHrLvName Sync="TRUE">dataset</mdHrLvName><refSysInfo><RefSystem><refSysID><identCode code="4326" Sync="TRUE"/><idCodeSpace Sync="TRUE">EPSG</idCodeSpace><idVersion Sync="TRUE">6.2(3.0.1)</idVersion></refSysID></RefSystem></refSysInfo><spatRepInfo><VectSpatRep><geometObjs Name="2. Minor fault lines"><geoObjTyp><GeoObjTypCd value="002" Sync="TRUE"></GeoObjTypCd></geoObjTyp><geoObjCnt Sync="TRUE">228</geoObjCnt></geometObjs><topLvl><TopoLevCd value="001" Sync="TRUE"></TopoLevCd></topLvl></VectSpatRep></spatRepInfo><spdoinfo><ptvctinf><esriterm Name="2. Minor fault lines"><efeatyp Sync="TRUE">Simple</efeatyp><efeageom code="3" Sync="TRUE"></efeageom><esritopo Sync="TRUE">FALSE</esritopo><efeacnt Sync="TRUE">228</efeacnt><spindex Sync="TRUE">TRUE</spindex><linrefer Sync="TRUE">FALSE</linrefer></esriterm></ptvctinf></spdoinfo><Binary><Thumbnail><Data EsriPropertyType="PictureX">/9j/4AAQSkZJRgABAQEAYABgAAD/2wBDAAMCAgMCAgMDAwMEAwMEBQgFBQQEBQoHBwYIDAoMDAsK
